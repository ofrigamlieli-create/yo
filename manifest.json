{
  "manifest_version": 3,
  "name": "Kani",
  "key": "",
  "version": "0.0.1",
  "description": "Understand what you read — instant TLDRs, term explanations, and concept diagrams.",
  "permissions": ["storage", "identity"],
  "host_permissions": ["https://otyvkolsfbipzmonpwzf.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": false,
      "run_at": "document_idle",
      "js": ["js/selection-detector.js", "js/selection-listener.js", "js/mock-tldr.js", "js/widget-shadow.js", "js/widget.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["css/widget.css"],
      "matches": ["<all_urls>"]
    }
  ]
}

