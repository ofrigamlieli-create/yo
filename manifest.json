{
  "manifest_version": 3,
  "name": "Yō",
  "version": "0.0.1",
  "description": "Understand what you read — instant TLDRs, term explanations, and concept diagrams.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": false,
      "run_at": "document_idle",
      "js": ["js/selection-detector.js", "js/selection-listener.js"]
    }
  ]
}

